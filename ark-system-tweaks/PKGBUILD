pkgname=ark-system-tweaks
pkgver=1.0.0
pkgrel=16
pkgdesc="System configuration and tweaks for Ark Linux"
arch=('any')
license=('MIT')

package() {
  # 1. OSTree prepare-root config
  install -Dm644 /dev/null "$pkgdir/etc/ostree/prepare-root.conf"
  echo '[sysroot]' > "$pkgdir/etc/ostree/prepare-root.conf"

  # 2. System tweaks hook (for plymouth and os-release)
  install -Dm644 /dev/null "$pkgdir/usr/share/libalpm/hooks/99-ark-system-tweaks.hook"
  cat <<EOF > "$pkgdir/usr/share/libalpm/hooks/99-ark-system-tweaks.hook"
[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = filesystem
Target = plymouth
Target = ark-system-tweaks

[Action]
Description = Applying Ark Linux system tweaks...
When = PostTransaction
Exec = /usr/bin/bash -c "sed -i 's/Theme=spinner/Theme=bgrt/' /etc/plymouth/plymouthd.conf 2>/dev/null || true; sed -i 's/VERSION_ID=.*/VERSION_ID=\"rolling\"/' /usr/lib/os-release 2>/dev/null || true"
EOF

  # 3. Emergency service override
  install -Dm644 /dev/null "$pkgdir/etc/systemd/system/emergency.service.d/override.conf"
  echo -e "[Service]\nEnvironment=SYSTEMD_SULOGIN_FORCE=1" > "$pkgdir/etc/systemd/system/emergency.service.d/override.conf"

  # 4. Silent boot kargs
  install -Dm644 /dev/null "$pkgdir/usr/lib/bootc/kargs.d/01-silent-boot.toml"
  echo 'kargs = ["quiet", "splash", "loglevel=3", "rd.udev.log_priority=3", "vt.global_cursor_default=0", "boot.shell_on_fail=1"]' > "$pkgdir/usr/lib/bootc/kargs.d/01-silent-boot.toml"

  # 5. Sudoers wheel group
  install -Dm644 /dev/null "$pkgdir/etc/sudoers.d/10-ark-wheel"
  cat <<'EOF' > "$pkgdir/etc/sudoers.d/10-ark-wheel"
%wheel ALL=(ALL:ALL) NOPASSWD: ALL
EOF

  # 6. Polkit wheel rule
  install -Dm644 /dev/null "$pkgdir/etc/polkit-1/rules.d/10-ark-wheel.rules"
  cat <<'EOF' > "$pkgdir/etc/polkit-1/rules.d/10-ark-wheel.rules"
polkit.addRule(function(action, subject) {
  if (subject.isInGroup("wheel")) {
    return polkit.Result.YES;
  }
});
EOF

  # 7. Arch container entry
  install -Dm755 /dev/null "$pkgdir/usr/share/ark/enter-arch.sh"
  cat <<'EOF' > "$pkgdir/usr/share/ark/enter-arch.sh"
#!/bin/sh

ATTEMPT=1
while [ "$ATTEMPT" -le 3 ]; do
  if ping -c 1 -W 5 hub.docker.com >/dev/null 2>&1; then
    break
  fi
  if [ "$ATTEMPT" -eq 3 ]; then
    echo "No internet. Come back when connected."
    sleep 5
    exit 1
  fi
  echo "No internet. Retrying ($((ATTEMPT + 1))/3)..."
  sleep 3
  ATTEMPT=$((ATTEMPT + 1))
done

if ! distrobox list --no-color 2>/dev/null | grep -qw "arch"; then
  distrobox create --name arch --image docker.io/archlinux:latest -Y
fi

distrobox enter arch -- bash -c '
  if [ ! -x /usr/local/bin/distrobox ]; then
    sudo tee /usr/local/bin/distrobox > /dev/null << "DEOF"
#!/bin/bash
exec distrobox-host-exec distrobox "$@"
DEOF
    sudo chmod +x /usr/local/bin/distrobox
  fi
' || true

rm -f "$HOME/.local/share/applications/arch.desktop"

exec distrobox enter arch --additional-flags "--workdir $PWD"
EOF

  # 8. GRUB update script (regenerate grub.cfg from BLS entries)
  install -Dm755 /dev/null "$pkgdir/usr/share/ark/grub-update.sh"
  cat > "$pkgdir/usr/share/ark/grub-update.sh" << 'GRUBEOF'
#!/bin/bash
ROOT_UUID=$(findmnt -no UUID / 2>/dev/null || echo "")
BOOT_UUID=$(findmnt -no UUID /boot 2>/dev/null || true)
HAS_SEP_BOOT=false
[ -n "$BOOT_UUID" ] && [ "$BOOT_UUID" != "$ROOT_UUID" ] && HAS_SEP_BOOT=true
GRUB_CFG="/boot/grub/grub.cfg"
mkdir -p "$(dirname "$GRUB_CFG")"
printf "set default=0\nset timeout=5\n\n" > "$GRUB_CFG"
entries=()
for f in /boot/loader/entries/ostree-*.conf; do
  [ -f "$f" ] && entries+=("$f")
done
if [ ${#entries[@]} -eq 0 ]; then
  {
    echo 'menuentry "Arch Linux" {'
    echo "    search --no-floppy --fs-uuid $ROOT_UUID --set=root"
    echo "    linux /boot/vmlinuz-linux root=UUID=$ROOT_UUID rw quiet splash loglevel=3"
    echo "    initrd /boot/initramfs-linux.img"
    echo '}'
  } >> "$GRUB_CFG"
  echo "Warning: No BLS entries found, generated fallback grub.cfg"
  exit 0
fi
IFS=$'\n'
sorted=($(sort -t- -k2 -rn <<<"${entries[*]}"))
unset IFS
count=0
for entry_file in "${sorted[@]}"; do
  title=$(sed -n 's/^title //p' "$entry_file" | head -n1)
  linux_rel=$(sed -n 's/^linux //p' "$entry_file" | head -n1)
  initrd_rel=$(sed -n 's/^initrd //p' "$entry_file" | head -n1)
  boot_opts=$(sed -n 's/^options //p' "$entry_file" | head -n1)
  [ -z "$linux_rel" ] && continue
  if [ ! -f "$linux_rel" ] && [ ! -f "/boot/${linux_rel#/boot/}" ]; then
    echo "Warning: Skipping BLS entry $entry_file — kernel not found: $linux_rel"
    continue
  fi
  if [ ! -f "$initrd_rel" ] && [ ! -f "/boot/${initrd_rel#/boot/}" ]; then
    echo "Warning: Skipping BLS entry $entry_file — initrd not found: $initrd_rel"
    continue
  fi
  if [ "$HAS_SEP_BOOT" = true ]; then
    linux_path='($boot_root)'"$linux_rel"
    initrd_path='($boot_root)'"$initrd_rel"
  else
    linux_path='($root)'"$linux_rel"
    initrd_path='($root)'"$initrd_rel"
  fi
  label="$title"
  [ "$count" -gt 0 ] && label="$title (previous)"
  {
    echo 'menuentry "'"$label"'" {'
    echo "    search --no-floppy --fs-uuid $ROOT_UUID --set=root"
    if [ "$HAS_SEP_BOOT" = true ]; then
      echo "    search --no-floppy --fs-uuid $BOOT_UUID --set=boot_root"
    fi
    echo "    linux $linux_path $boot_opts"
    echo "    initrd $initrd_path"
    echo '}'
    echo ''
  } >> "$GRUB_CFG"
  count=$((count + 1))
done
echo "Generated $count GRUB entries from OSTree BLS entries"
GRUBEOF

  # 9. GRUB update systemd service
  install -Dm644 /dev/null "$pkgdir/etc/systemd/system/ark-grub-update.service"
  cat <<'SVCEOF' > "$pkgdir/etc/systemd/system/ark-grub-update.service"
[Unit]
Description=Ark GRUB boot entry regeneration from OSTree deployments
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/share/ark/grub-update.sh

[Install]
WantedBy=multi-user.target
SVCEOF

  # 10. GSchema override (theme + app folders)
  install -Dm644 /dev/null "$pkgdir/usr/share/glib-2.0/schemas/99-ark-theme.gschema.override"
  cat <<'EOF' > "$pkgdir/usr/share/glib-2.0/schemas/99-ark-theme.gschema.override"
[org.gnome.desktop.interface]
icon-theme='MoreWaita'

[org.gnome.desktop.app-folders]
folder-children=['System', 'Utilities', 'Containers']

[org.gnome.desktop.app-folders.folder:/org/gnome/desktop/app-folders/folders/Containers/]
name='Containers'
translate=true
categories=['Distrobox']

[org.gnome.desktop.app-folders.folder:/org/gnome/desktop/app-folders/folders/System/]
name='System'
translate=true
apps=['org.gnome.Settings.desktop', 'com.zamkara.alga.desktop', 'gnome-system-monitor.desktop']

[org.gnome.desktop.app-folders.folder:/org/gnome/desktop/app-folders/folders/Utilities/]
name='Utilities'
translate=true
apps=['org.gnome.Console.desktop', 'com.ranfdev.DistroShelf.desktop', 'com.github.marhkb.Pods.desktop', 'org.gnome.DejaDup.desktop', 'org.gnome.FileRoller.desktop', 'org.gnome.fonts.desktop', 'org.gnome.Loupe.desktop', 'org.gnome.seahorse.Application.desktop']
EOF
  # 11. bootupd symlinks
  install -d "$pkgdir/usr/bin"
  ln -s /usr/libexec/bootupd "$pkgdir/usr/bin/bootupd"

  # 12. Compile and package all UTF-8 locales
  # NOTE: do NOT ship /etc/locale.gen — it is owned by glibc and would conflict.
  # Use a temp copy for compilation only; ship only the compiled locale-archive.
  mkdir -p "$pkgdir/usr/lib/locale"
  cp /etc/locale.gen /tmp/ark-locale-build.gen
  sed -i 's/^#\(.*UTF-8.*\)/\1/' /tmp/ark-locale-build.gen
  sed -i '/@/s/^/#/' /tmp/ark-locale-build.gen

  echo "Pre-compiling all UTF-8 locales into package..."
  grep -v '^#' /tmp/ark-locale-build.gen | while read -r line; do
    if [ -n "$line" ]; then
      locale=$(echo "$line" | awk '{print $1}')
      charmap=$(echo "$line" | awk '{print $2}')
      localedef -i "${locale%.*}" -f "$charmap" --alias /usr/share/locale/locale.alias "$pkgdir/usr/lib/locale/locale-archive" || true
    fi
  done
  rm -f /tmp/ark-locale-build.gen

}
