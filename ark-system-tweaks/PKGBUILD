pkgname=ark-system-tweaks
pkgver=1.0.0
pkgrel=3
pkgdesc="System configuration and tweaks for Ark Linux"
arch=('any')
license=('MIT')

package() {
  # 1. OSTree prepare-root config
  install -Dm644 /dev/null "$pkgdir/etc/ostree/prepare-root.conf"
  echo '[sysroot]' > "$pkgdir/etc/ostree/prepare-root.conf"

  # 2. System tweaks hook (for plymouth and os-release)
  install -Dm644 /dev/null "$pkgdir/usr/share/libalpm/hooks/99-ark-system-tweaks.hook"
  cat <<EOF > "$pkgdir/usr/share/libalpm/hooks/99-ark-system-tweaks.hook"
[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = filesystem
Target = plymouth
Target = ark-system-tweaks

[Action]
Description = Applying Ark Linux system tweaks...
When = PostTransaction
Exec = /usr/bin/bash -c "sed -i 's/Theme=spinner/Theme=bgrt/' /etc/plymouth/plymouthd.conf 2>/dev/null || true; sed -i 's/VERSION_ID=.*/VERSION_ID=\"rolling\"/' /usr/lib/os-release 2>/dev/null || true"
EOF

  # 3. Emergency service override
  install -Dm644 /dev/null "$pkgdir/etc/systemd/system/emergency.service.d/override.conf"
  echo -e "[Service]\nEnvironment=SYSTEMD_SULOGIN_FORCE=1" > "$pkgdir/etc/systemd/system/emergency.service.d/override.conf"

  # 4. Silent boot kargs
  install -Dm644 /dev/null "$pkgdir/usr/lib/bootc/kargs.d/01-silent-boot.toml"
  echo 'kargs = ["quiet", "splash", "loglevel=3", "rd.udev.log_priority=3", "vt.global_cursor_default=0", "boot.shell_on_fail=1"]' > "$pkgdir/usr/lib/bootc/kargs.d/01-silent-boot.toml"

  # 6. Distrobox pacman hooks
  install -Dm644 /dev/null "$pkgdir/usr/share/ark-distrobox/hooks/99-distrobox-export-install.hook"
  cat <<EOF > "$pkgdir/usr/share/ark-distrobox/hooks/99-distrobox-export-install.hook"
[Trigger]
Operation = Install
Operation = Upgrade
Type = Path
Target = usr/share/applications/*.desktop

[Action]
Description = Exporting applications to host...
When = PostTransaction
NeedsTargets
Exec = /usr/bin/bash -c 'USER_NAME=\$(id -un 1000 2>/dev/null || echo root); while read -r f; do sudo -u "\$USER_NAME" distrobox-export --app "\$(basename "\$f" .desktop)" --export-label "none" 2>/dev/null || true; done'
EOF

  install -Dm644 /dev/null "$pkgdir/usr/share/ark-distrobox/hooks/99-distrobox-export-remove.hook"
  cat <<EOF > "$pkgdir/usr/share/ark-distrobox/hooks/99-distrobox-export-remove.hook"
[Trigger]
Operation = Remove
Type = Path
Target = usr/share/applications/*.desktop

[Action]
Description = Un-exporting applications from host...
When = PreTransaction
NeedsTargets
Exec = /usr/bin/bash -c 'USER_NAME=\$(id -un 1000 2>/dev/null || echo root); while read -r f; do sudo -u "\$USER_NAME" distrobox-export -d --app "\$(basename "\$f" .desktop)" 2>/dev/null || true; done'
EOF

  # 7. Background Distrobox initialization
  install -Dm644 /dev/null "$pkgdir/usr/lib/systemd/user/distrobox-init.service"
  cat <<'EOF' > "$pkgdir/usr/lib/systemd/user/distrobox-init.service"
[Unit]
Description=Initialize Default Distrobox
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/bash -c 'if ! distrobox list | grep -q "arch"; then distrobox create --name arch --image docker.io/archlinux:latest --init-hooks "mkdir -p /etc/pacman.d/hooks && cp /run/host/usr/share/ark-distrobox/hooks/*.hook /etc/pacman.d/hooks/" -Y; fi'
RemainAfterExit=yes

[Install]
WantedBy=default.target
EOF

  install -d "$pkgdir/usr/lib/systemd/user/default.target.wants"
  ln -s /usr/lib/systemd/user/distrobox-init.service "$pkgdir/usr/lib/systemd/user/default.target.wants/distrobox-init.service"

  install -Dm644 /dev/null "$pkgdir/usr/share/glib-2.0/schemas/99-ark-theme.gschema.override"
  cat <<'EOF' > "$pkgdir/usr/share/glib-2.0/schemas/99-ark-theme.gschema.override"
[org.gnome.desktop.interface]
icon-theme='MoreWaita'

[org.gnome.desktop.app-folders]
folder-children=['System', 'Utilities', 'YaST', 'Pardus', 'Containers']

[org.gnome.desktop.app-folders.folder:/org/gnome/desktop/app-folders/folders/Containers/]
name='Containers'
translate=true
categories=['Distrobox']

[org.gnome.desktop.app-folders.folder:/org/gnome/desktop/app-folders/folders/System/]
apps=['nm-connection-editor.desktop', 'org.gnome.baobab.desktop', 'org.gnome.DiskUtility.desktop', 'org.gnome.Logs.desktop', 'org.freedesktop.MalcontentControl.desktop', 'org.gnome.SystemMonitor.desktop', 'org.gnome.tweaks.desktop', 'bvnc.desktop', 'bssh.desktop', 'qvidcap.desktop', 'qv4l2.desktop', 'tuned-gui.desktop', 'rmpc.desktop', 'com-maxrave-simpmusic-MainKt.desktop', 'xarchiver.desktop', 'org.gnome.Settings.desktop', 'com.zamkara.alga.desktop', 'avahi-discover.desktop', 'lstopo.desktop']

[org.gnome.desktop.app-folders.folder:/org/gnome/desktop/app-folders/folders/Utilities/]
apps=['gnome-abrt.desktop', 'gnome-system-log.desktop', 'org.gnome.Connections.desktop', 'org.gnome.DejaDup.desktop', 'org.gnome.Dictionary.desktop', 'org.gnome.Evince.desktop', 'org.gnome.FileRoller.desktop', 'org.gnome.fonts.desktop', 'org.gnome.Loupe.desktop', 'org.gnome.seahorse.Application.desktop', 'org.gnome.Usage.desktop', 'vinagre.desktop', 'org.gnome.Ptyxis.desktop', 'com.ranfdev.DistroShelf.desktop', 'com.github.marhkb.Pods.desktop']
EOF
  # 10. bootupd symlinks
  install -d "$pkgdir/usr/bin"
  ln -s /usr/libexec/bootupd "$pkgdir/usr/bin/bootupd"
}
